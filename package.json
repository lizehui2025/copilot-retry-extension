{
  "name": "copilot-retry-proxy",
  "displayName": "Copilot Retry Proxy",
  "description": "Local retry proxy that auto-retries third-party API rate limit errors (11210 / 429 / 5xx)",
  "version": "0.0.7",
  "publisher": "ITAS6666",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lizehui2025/copilot-retry-extension.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotRetryProxy.start",
        "title": "Copilot Retry Proxy: Start Proxy"
      },
      {
        "command": "copilotRetryProxy.stop",
        "title": "Copilot Retry Proxy: Stop Proxy"
      },
      {
        "command": "copilotRetryProxy.restart",
        "title": "Copilot Retry Proxy: Restart Proxy"
      },
      {
        "command": "copilotRetryProxy.showStatus",
        "title": "Copilot Retry Proxy: Show Status"
      },
      {
        "command": "copilotRetryProxy.showLog",
        "title": "Copilot Retry Proxy: Show Log"
      },
      {
        "command": "copilotRetryProxy.openConfig",
        "title": "Copilot Retry Proxy: Open Upstream Config"
      }
    ],
    "configuration": {
      "title": "Copilot Retry Proxy",
      "properties": {
        "copilotRetryProxy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start proxy when VS Code starts"
        },
        "copilotRetryProxy.port": {
          "type": "number",
          "default": 8787,
          "description": "Proxy listen port"
        },
        "copilotRetryProxy.maxRetries": {
          "type": "number",
          "default": 5,
          "description": "Maximum retry count"
        },
        "copilotRetryProxy.initialBackoffMs": {
          "type": "number",
          "default": 1000,
          "description": "Initial backoff time (ms)"
        },
        "copilotRetryProxy.backoffMultiplier": {
          "type": "number",
          "default": 2,
          "description": "Backoff multiplier"
        },
        "copilotRetryProxy.maxBackoffMs": {
          "type": "number",
          "default": 30000,
          "description": "Maximum backoff time (ms)"
        },
        "copilotRetryProxy.sniffTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "First-frame sniff timeout (ms). Increase for slow upstreams"
        },
        "copilotRetryProxy.upstreams": {
          "type": "object",
          "default": {},
          "description": "Upstream mapping: path prefix → upstream baseURL. Leave empty to auto-read from upstreams.json",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/*.test.js",
    "lint": "tsc -p ./ --noEmit",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.4.0"
  }
}
